DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production-use-50-random-chars
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://erp_user:erp_pass@localhost:5432/moveis_erp
# Or SQLite for dev:
# DATABASE_URL=sqlite:///db.sqlite3

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# AWS S3 (optional for media in production)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# WhatsApp API (Evolution API or Twilio)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Assinatura Digital
ASSINATURA_API_URL=
ASSINATURA_API_TOKEN=

# Fiscal (NFe / NFSe)
FISCAL_PROVEDOR=nfse
FISCAL_API_URL=
FISCAL_API_TOKEN=

# Segurança SSL (False para servidor local/HyperV sem HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Sentry (production)
SENTRY_DSN=
